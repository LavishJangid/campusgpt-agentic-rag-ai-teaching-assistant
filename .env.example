# ============================================
# CampusGPT — Environment Config
# ============================================

# Google Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Application Settings
APP_NAME=CampusGPT
APP_VERSION=2.0.0
APP_ENV=development
DEBUG=true

# Backend Settings
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://localhost:8000

# Frontend Settings
FRONTEND_PORT=8501

# Database
DATABASE_URL=sqlite:///./data/campusgpt.db

# JWT Authentication
JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
AUTH_DISABLED=false

# Redis (conversation memory)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=true

# ChromaDB Settings
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=teaching_assistant

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Reranker
RERANKER_MODEL=BAAI/bge-reranker-base
RERANKER_DISABLED=false
RETRIEVAL_FETCH_K=10
RERANK_TOP_K=3

# LangGraph Agent
USE_LANGGRAPH_AGENT=true

# RAGAS Evaluation
RAGAS_DISABLED=false

# LLM Settings
LLM_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# RAG Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# Rate Limiting
RATE_LIMIT=30/minute

# Logging
LOG_LEVEL=INFO
LOG_FILE=artifacts/logs/app.log

# Upload Settings
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,txt,pptx
